    <!-- Action -->
    <record id="action_test_model" model="ir.actions.act_window">
        <field name="name">Invoice Extractions</field>
        <field name="res_model">test.model</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Upload your first invoice!
            </p>
            <p>
                Our AI will automatically detect fields and line items from your image.
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_test_root" name="Invoice AI OCR" sequence="10"/>
    <menuitem id="menu_test_model" name="Processed Invoices" parent="menu_test_root" action="action_test_model" sequence="10"/>

</odoo>